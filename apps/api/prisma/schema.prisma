// KOEN — Prisma Schema
// Based on Engineering Constraints v6, §3.1 (Data Model)
// Designed for multi-user and multi-project from day one.
// Stage 1 uses one user — schema already supports a team of 20 without changes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum ProjectStage {
  foundations
  framing
  cladding
  finishing
}

enum DataCategory {
  task
  material
  hours
  event
  note
}

// ─────────────────────────────────────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  WORKER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String?  // Optional for now to support Stage 1 seed users, but required for new signups
  role         UserRole @default(WORKER)
  language     String   @default("en")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  projects    Project[]
  records     VoiceRecord[]
  invitations Invitation[]
  memberships ProjectMember[]

  @@map("users")
}

model Invitation {
  id        String           @id @default(uuid())
  email     String
  token     String           @unique
  role      UserRole         @default(WORKER)
  status    InvitationStatus @default(PENDING)
  expiresAt DateTime
  projectId String?
  createdAt DateTime         @default(now())

  invitedById String
  invitedBy   User   @relation(fields: [invitedById], references: [id])

  @@map("invitations")
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model Project {
  id        String       @id @default(uuid())
  userId    String
  name      String
  client    String
  startDate DateTime
  stage     ProjectStage
  createdAt DateTime     @default(now())

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  records VoiceRecord[]
  members ProjectMember[]

  @@map("projects")
}

/// Raw voice recording + transcript. Stored separately from extracted data.
/// If extraction logic improves, old recordings can be reprocessed without data loss.
model VoiceRecord {
  id              String   @id @default(uuid())
  projectId       String
  userId          String
  audioUrl        String   // Temp path during processing in Stage 1, durable URL in later stages
  transcript      String
  language        String   // "en" or "es"
  confidenceScore Float    @default(0)
  createdAt       DateTime @default(now())

  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  extracted ExtractedData[]

  @@map("voice_records")
}

/// Structured data extracted from a voice recording.
/// One VoiceRecord can produce multiple ExtractedData rows (one per category detected).
model ExtractedData {
  id            String       @id @default(uuid())
  voiceRecordId String
  projectId     String
  userId        String
  category      DataCategory
  content       Json         // Flexible per category: { description, start, end, amount, unit, ... }
  confidence    Float        @default(0)
  confirmed     Boolean      @default(false) // true = worker confirmed via ConfirmCard
  createdAt     DateTime     @default(now())

  voiceRecord VoiceRecord @relation(fields: [voiceRecordId], references: [id], onDelete: Cascade)

  @@map("extracted_data")
}
