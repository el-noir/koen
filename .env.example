# Environment Variables — KOEN
# Copy this file to .env and fill in your values. Never commit .env to git.

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/koen

# ── API Server ──────────────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:3000

# ── AI Services ─────────────────────────────────────────────────────────────
# OpenAI — used for Whisper transcription
OPENAI_API_KEY=sk-...

# Groq — used for intent extraction in Stage 1 (fast, free tier)
GROQ_API_KEY=gsk_...

# Confidence threshold — records below this score show the ConfirmCard
CONFIDENCE_THRESHOLD=0.80

# ── Stage 2+ ─────────────────────────────────────────────────────────────────
# Anthropic Claude (not needed for Stage 1)
# ANTHROPIC_API_KEY=sk-ant-...
