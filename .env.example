# Environment Variables - KOEN
# Copy this file to .env and fill in your values. Never commit .env to git.

# Database
# Required. The API refuses to boot if this is missing or left as the example value.
DATABASE_URL=postgresql://postgres:password@localhost:5432/koen

# API Server
PORT=4000
# Optional, but if provided it must be a valid absolute URL.
FRONTEND_URL=http://localhost:3000

# AI Services
# Required. Groq is used for both transcription and extraction in Stage 1.
# The API refuses to boot if this is missing or left as the placeholder.
GROQ_API_KEY=gsk_...

# Confidence threshold - records below this score show the ConfirmCard.
# Optional, but if provided it must be a number between 0 and 1.
CONFIDENCE_THRESHOLD=0.80

# Stage 2+
# ── DigitalOcean Spaces (Phase 3.3) ──────────────────────────────────────────
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_ENDPOINT=
DO_SPACES_BUCKET=
DO_SPACES_REGION=

# ── Email Service (Phase 3.5) ──────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM='"KOEN Site Assistant" <noreply@koen.app>'

# Anthropic Claude (not needed for Stage 1)
# ANTHROPIC_API_KEY=sk-ant-...
